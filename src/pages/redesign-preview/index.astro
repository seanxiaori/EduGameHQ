---
import PreviewLayout from '../../layouts/PreviewLayout.astro';
import PreviewLogo from '../../components/redesign/PreviewLogo.astro';
import PreviewNavIcon from '../../components/redesign/PreviewNavIcon.astro';
import PreviewGameTile from '../../components/redesign/PreviewGameTile.astro';
import PreviewSearchForm from '../../components/redesign/PreviewSearchForm.astro';
import PreviewLanguageMenu from '../../components/redesign/PreviewLanguageMenu.astro';
import PreviewAdSlot from '../../components/redesign/PreviewAdSlot.astro';
import PreviewSidebar from '../../components/redesign/PreviewSidebar.astro';
import { compareHomePriority, isFootballGame } from '../../utils/footballGames';
import games from '../../data/games.json';
import '../../styles/redesign-preview.css';

interface Props {
  isProductionHome?: boolean;
}

const { isProductionHome = false } = Astro.props;
const allGames = games as any[];
const buildDate = new Date();
const daySeed = Math.floor(Date.UTC(buildDate.getUTCFullYear(), buildDate.getUTCMonth(), buildDate.getUTCDate()) / 86400000);
const isWorldCupWindow = buildDate.getUTCFullYear() === 2026 && (buildDate.getUTCMonth() === 5 || buildDate.getUTCMonth() === 6);
const hashText = (text: string) => {
  let hash = 2166136261;
  for (let index = 0; index < text.length; index += 1) {
    hash ^= text.charCodeAt(index);
    hash = Math.imul(hash, 16777619);
  }
  return hash >>> 0;
};
const shuffleWithSeed = <T,>(items: T[], seed: number) => {
  const result = [...items];
  let state = seed || 1;
  for (let index = result.length - 1; index > 0; index -= 1) {
    state = (Math.imul(state, 1664525) + 1013904223) >>> 0;
    const swapIndex = state % (index + 1);
    [result[index], result[swapIndex]] = [result[swapIndex], result[index]];
  }
  return result;
};
const orderDaily = (pool: any[], salt: string, prioritizeFootball = false) => {
  const seed = daySeed + hashText(salt);
  const cleanPool = [...pool].sort(compareHomePriority);

  if (!prioritizeFootball || !isWorldCupWindow) {
    return shuffleWithSeed(cleanPool, seed);
  }

  return [
    ...shuffleWithSeed(cleanPool.filter(isFootballGame), seed + 11),
    ...shuffleWithSeed(cleanPool.filter((game) => !isFootballGame(game)), seed + 29),
  ];
};
const featuredPool = allGames.filter((game) => game.featured || game.trending || game.isNew);
const footballPool = allGames.filter(isFootballGame);
const newGamesPool = allGames.filter((game) => game.isNew);
const featured = orderDaily(featuredPool, 'home-featured', true).slice(0, 60);
const football = orderDaily(footballPool, 'home-football').slice(0, 60);
const newGames = orderDaily(newGamesPool, 'home-new', true).slice(0, 60);
const mathGames = orderDaily(allGames.filter((game) => game.category === 'math'), 'home-math').slice(0, 12);
const puzzleGames = orderDaily(allGames.filter((game) => game.category === 'puzzle'), 'home-puzzle').slice(0, 12);
const heroGames = orderDaily([...football.slice(0, 24), ...featured], 'home-hero', true).slice(0, 3);
const heroSideGames = orderDaily(featured, 'home-hero-side', true).slice(0, 6);
const randomGame = orderDaily(featuredPool.length ? featuredPool : allGames, 'home-random', true)[0] || allGames[0];
const footballHref = '/football-games/';
const categoryDefinitions = [
  ['sports', 'Sports Games', '/sports-games/', 'sports', 'Team challenges, timing, coordination, and quick reflex practice.'],
  ['football', 'Football Games', footballHref, 'football', 'World Cup soccer, penalties, free kicks, and quick football matches.'],
  ['math', 'Math Games', '/math-games/', 'math', 'Numbers, logic, arithmetic, and pattern practice through play.'],
  ['puzzle', 'Puzzle Games', '/puzzle-games/', 'puzzle', 'Spatial reasoning, matching, sorting, and problem solving.'],
  ['strategy', 'Strategy Games', '/best-games/?category=strategy', 'popular', 'Planning, tradeoffs, and decision-making challenges.'],
  ['science', 'Science Games', '/science-games/', 'science', 'Explore systems, experiments, nature, and scientific thinking.'],
  ['coding', 'Coding Games', '/coding-games/', 'popular', 'Algorithms, debugging, CSS, logic, and programming concepts.'],
  ['arcade', 'Arcade Games', '/best-games/?category=arcade', 'new', 'Fast browser games with pattern recognition and timing.'],
  ['language', 'Word Games', '/language-games/', 'word', 'Vocabulary, spelling, reading, and word discovery games.'],
  ['adventure', 'Adventure Games', '/best-games/?category=adventure', 'home', 'Exploration, quests, and lightweight story-based play.'],
  ['memory', 'Memory Games', '/memory-games/', 'favorites', 'Recall, matching, concentration, and visual memory training.'],
  ['creative', 'Creative Games', '/best-games/?category=creative', 'science', 'Drawing, music, building, and open-ended creative play.'],
  ['geography', 'Geography Games', '/geography-games/', 'sports', 'Maps, flags, countries, capitals, and world knowledge.'],
  ['art', 'Art Games', '/best-games/?category=art', 'word', 'Color, composition, design, and visual creativity.'],
] as const;
const categorySections = categoryDefinitions
  .map(([id, title, href, icon, description]) => ({
    id,
    title,
    href,
    icon,
    description,
    games: id === 'football'
      ? football.slice(0, 24)
      : orderDaily(allGames.filter((game) => game.category === id), `home-category-${id}`, true).slice(0, 24),
  }))
  .filter((section) => section.games.length > 0);
const shareLinks = [
  ['Facebook', 'facebook', 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fwww.edugamehq.com%2F'],
  ['X', 'x', 'https://twitter.com/intent/tweet?url=https%3A%2F%2Fwww.edugamehq.com%2F&text=Free%20educational%20browser%20games'],
  ['LinkedIn', 'linkedin', 'https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fwww.edugamehq.com%2F'],
  ['YouTube', 'youtube', 'https://www.youtube.com/'],
  ['Discord', 'discord', 'https://discord.com/'],
];
const homeHref = isProductionHome ? '/' : '/redesign-preview/';
const quickLinks = [
  ['All Games', '/best-games/'],
  ['Math', '/math-games/'],
  ['Puzzle', '/puzzle-games/'],
  ['Science', '/science-games/'],
  ['Sports', '/sports-games/'],
  ['Football', footballHref],
  ['Random Game', `/games/${randomGame?.slug || '2048'}/`],
];
const quietLinks = [
  ['About', '/about/', 'about'],
  ['Developers', '/about/', 'about'],
  ['Kids site', '/', 'home'],
  ['Jobs', '/about/', 'about'],
  ['Info for parents', '/help/', 'help'],
  ['Terms & conditions', '/terms-of-service/', 'privacy'],
  ['Privacy', '/privacy-policy/', 'privacy'],
  ['All games', '/best-games/', 'all'],
  ['Search', '/search/', 'search'],
  ['Help', '/help/', 'help'],
];
---

<PreviewLayout
  title={isProductionHome ? 'Free Educational Games for Kids - EduGameHQ' : 'EduGameHQ Redesign Preview'}
  description={isProductionHome ? 'Play free educational browser games for math, science, language, puzzle, sports, coding, and creative learning.' : 'A CrazyGames-inspired redesign preview for EduGameHQ.'}
  robots={isProductionHome ? 'index, follow' : 'noindex, nofollow'}
  canonical={isProductionHome ? 'https://www.edugamehq.com/' : undefined}
>
  <main id="top" class="redesign-preview">
    <header class="preview-topbar">
      <PreviewLogo href={homeHref} />
      <PreviewSearchForm />
      <div class="preview-actions">
        <PreviewLanguageMenu />
        <a class="preview-chip" href={footballHref}>Football</a>
        <a class="preview-icon-button" href="/favorites/" aria-label="Favorites">♡</a>
      </div>
    </header>

    <div class="preview-shell">
      <PreviewSidebar activePlay="/" />

      <div class="preview-main">
        <div class="preview-content-layout">
          <div class="preview-feed">
            <div class="preview-panel preview-feature-board expanded">
              <div class="preview-hero-carousel" aria-label="Featured game carousel">
                {heroGames.map((game, index) => (
                  <a class="preview-hero-slide" href={`/games/${game.slug}/`} style={`--slide-index: ${index}`}>
                    <img src={game.image || game.thumbnailUrl || '/images/logo.svg'} alt={`${game.title} game cover`} loading={index === 0 ? 'eager' : 'lazy'} />
                    <span class="preview-hero-caption">
                      <strong>{game.title}</strong>
                      <small>{(game.tags || []).slice(0, 2).join(' · ') || game.categoryName || game.category}</small>
                    </span>
                  </a>
                ))}
                <span class="preview-carousel-dots" aria-hidden="true">
                  {heroGames.map((_, index) => <i style={`--dot-index: ${index}`}></i>)}
                </span>
              </div>
              <div class="preview-side-stack hero-side">
                <div class="preview-mosaic-board" aria-label="More featured games">
                  {heroSideGames.map((game, index) => (
                    <a class={`preview-mosaic-tile tile-${index + 1}`} href={`/games/${game.slug}/`}>
                      <img src={game.image || game.thumbnailUrl || '/images/logo.svg'} alt={`${game.title} game cover`} loading="lazy" />
                      {(game.isNew || game.trending || game.featured) && <span class="tile-badge">{game.isNew ? 'New' : game.trending ? 'Hot' : 'Pick'}</span>}
                      <span class="mosaic-copy">
                        <strong>{game.title}</strong>
                        <small>{(game.tags || []).slice(0, 2).join(' · ') || game.categoryName || game.category}</small>
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            </div>

            <div class="preview-quick-strip">
              {quickLinks.map(([label, href]) => <a href={href}>{label}</a>)}
            </div>

            <section class="preview-section">
              <div class="preview-section-head">
                <div>
                  <h2>World Cup Football Games</h2>
                  <p>Soccer matches, penalty kicks, free kicks, and quick tournament challenges for football season.</p>
                </div>
                <a class="preview-ghost-button" href={footballHref}>View all</a>
              </div>
              <div class="preview-row" data-preview-daily-rotation data-rotation-limit="6" data-football-priority="true">
                {football.map((game, index) => (
                  <span class="preview-rotation-card" data-preview-rotation-card data-football="true" hidden={index >= 6}>
                    <PreviewGameTile game={game} />
                  </span>
                ))}
              </div>
            </section>

            <section class="preview-section">
              <PreviewAdSlot format="horizontal" slot="3312192068" />
            </section>

            <section class="preview-section">
              <div class="preview-section-head">
                <div>
                  <h2>Featured Games</h2>
                  <p>Fast picks for students, parents, teachers, and casual learners.</p>
                </div>
              </div>
              <div class="preview-row" data-preview-daily-rotation data-rotation-limit="6" data-football-priority="true">
                {featured.map((game, index) => (
                  <span class="preview-rotation-card" data-preview-rotation-card data-football={isFootballGame(game) ? 'true' : 'false'} hidden={index >= 6}>
                    <PreviewGameTile game={game} />
                  </span>
                ))}
              </div>
            </section>

            <section class="preview-section">
              <div class="preview-section-head">
                <div>
                  <h2>New Games</h2>
                  <p>Fresh browser games with local covers and catalog metadata.</p>
                </div>
              </div>
              <div class="preview-row" data-preview-daily-rotation data-rotation-limit="6" data-football-priority="true">
                {newGames.map((game, index) => (
                  <span class="preview-rotation-card" data-preview-rotation-card data-football={isFootballGame(game) ? 'true' : 'false'} hidden={index >= 6}>
                    <PreviewGameTile game={game} />
                  </span>
                ))}
              </div>
            </section>

            <section class="preview-section preview-learning-strip">
              <div class="preview-learning-head">
                <span>Logic Lab</span>
                <div>
                  <h2>Math and Puzzle Picks</h2>
                  <p>Numbers, spatial reasoning, pattern recognition, and quick classroom-friendly challenges.</p>
                </div>
                <a href="/math-games/">Explore math</a>
              </div>
              <div class="preview-learning-grid">
                {[...mathGames, ...puzzleGames].slice(0, 10).map((game, index) => (
                  <PreviewGameTile game={game} size={index === 0 ? 'wide' : undefined} />
                ))}
              </div>
            </section>

            <section class="preview-section preview-category-directory" aria-label="Game categories">
              <div class="preview-section-head">
                <div>
                  <h2>Browse by Category</h2>
                  <p>Every main game category gets a compact shelf on the homepage.</p>
                </div>
              </div>
              <div class="preview-category-shelves">
                {categorySections.map((section) => (
                  <section class="preview-category-shelf">
                    <div class="preview-category-shelf-head">
                      <div>
                        <span class="category-icon-pill"><PreviewNavIcon name={section.icon as any} tone="category" /></span>
                        <h3>{section.title}</h3>
                      </div>
                      <p>{section.description}</p>
                      <a href={section.href}>View all</a>
                    </div>
                    <div class="preview-row" data-preview-daily-rotation data-rotation-limit="6" data-football-priority={section.id === 'sports' ? 'true' : 'false'}>
                      {section.games.map((game, index) => (
                        <span class="preview-rotation-card" data-preview-rotation-card data-football={isFootballGame(game) ? 'true' : 'false'} hidden={index >= 6}>
                          <PreviewGameTile game={game} />
                        </span>
                      ))}
                    </div>
                  </section>
                ))}
              </div>
            </section>

            <section class="preview-bottom-actions" aria-label="Quick actions">
              <a class="preview-bottom-button secondary" href={`/games/${randomGame?.slug || '2048'}/`}>
                <PreviewNavIcon name="random" tone="action" />
                <span>Random Game</span>
              </a>
              <a class="preview-bottom-button primary" href="#top">
                <PreviewNavIcon name="top" tone="action" />
                <span>Back to Top</span>
              </a>
            </section>

            <footer class="preview-footer-dark">
              <div class="preview-footer-main">
                <PreviewLogo compact href={homeHref} />
                <p>Free educational browser games for quick play, classroom breaks, and curious learners.</p>
                <p class="preview-footer-copy">© 2026 EduGameHQ</p>
              </div>
              <div class="preview-footer-links">
                <strong>Explore</strong>
                <nav aria-label="Footer links">
                  {quietLinks.slice(0, 8).map(([label, href]) => <a href={href}>{label}</a>)}
                </nav>
              </div>
              <div class="preview-footer-social">
                <strong>Share</strong>
                <div class="preview-share-row" aria-label="Share EduGameHQ">
                  <span><PreviewNavIcon name="share" tone="action" />EduGameHQ</span>
                  {shareLinks.map(([label, icon, href]) => (
                    <a class="preview-social-button" href={href} target="_blank" rel="noopener noreferrer" aria-label={`Share on ${label}`}>
                      <PreviewNavIcon name={icon as any} tone="action" />
                    </a>
                  ))}
                </div>
              </div>
            </footer>

          </div>
        </div>
      </div>
    </div>
  <script is:inline>
    (() => {
      const today = new Date();
      const daySeed = Math.floor(Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()) / 86400000);
      const isWorldCupWindow = today.getFullYear() === 2026 && (today.getMonth() === 5 || today.getMonth() === 6);

      const hashText = (text) => {
        let hash = 2166136261;
        for (let index = 0; index < text.length; index += 1) {
          hash ^= text.charCodeAt(index);
          hash = Math.imul(hash, 16777619);
        }
        return hash >>> 0;
      };

      const shuffle = (items, seed) => {
        const result = [...items];
        let state = seed || 1;
        for (let index = result.length - 1; index > 0; index -= 1) {
          state = (Math.imul(state, 1664525) + 1013904223) >>> 0;
          const swapIndex = state % (index + 1);
          [result[index], result[swapIndex]] = [result[swapIndex], result[index]];
        }
        return result;
      };

      document.querySelectorAll('[data-preview-daily-rotation]').forEach((row, rowIndex) => {
        const limit = Number(row.dataset.rotationLimit || 6);
        const cards = Array.from(row.querySelectorAll('[data-preview-rotation-card]'));
        if (cards.length <= limit) {
          cards.forEach((card) => card.hidden = false);
          return;
        }

        const sectionLabel = row.closest('section')?.querySelector('h2,h3')?.textContent || rowIndex;
        const seed = daySeed + hashText(`${sectionLabel}`);
        const footballCards = cards.filter((card) => card.dataset.football === 'true');
        const otherCards = cards.filter((card) => card.dataset.football !== 'true');
        const shouldPrioritizeFootball = row.dataset.footballPriority === 'true' && isWorldCupWindow;

        let selected;
        if (shouldPrioritizeFootball && footballCards.length > 0) {
          const footballTarget = Math.min(Math.ceil(limit * 0.75), footballCards.length);
          selected = [
            ...shuffle(footballCards, seed + 11).slice(0, footballTarget),
            ...shuffle(otherCards, seed + 29).slice(0, limit - footballTarget),
          ];

          if (selected.length < limit) {
            const selectedSet = new Set(selected);
            selected.push(...shuffle(cards.filter((card) => !selectedSet.has(card)), seed + 47).slice(0, limit - selected.length));
          }
        } else {
          selected = shuffle(cards, seed).slice(0, limit);
        }

        const selectedSet = new Set(selected);
        cards.forEach((card) => card.hidden = !selectedSet.has(card));
        selected.forEach((card) => row.appendChild(card));
      });
    })();
  </script>
</PreviewLayout>
