---
import RedesignGameDetailPage from '../../components/redesign/RedesignGameDetailPage.astro';
import type { Game } from '../../types/game';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const gamesPath = path.join(process.cwd(), 'src', 'data', 'games.json');
  const gamesData: Game[] = JSON.parse(fs.readFileSync(gamesPath, 'utf-8'));

  return gamesData.map((game: Game) => ({
    params: { slug: game.slug },
    props: { game, allGames: gamesData },
  }));
}

interface Props {
  game: Game;
  allGames: Game[];
}

const { game, allGames }: Props = Astro.props;
---

<RedesignGameDetailPage game={game} allGames={allGames} />
