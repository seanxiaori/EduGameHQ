</style>

<script>
  // 游戏控制函数
  function toggleFullscreen() {
    const iframe = document.querySelector('.game-iframe') as HTMLIFrameElement;
    if (!iframe) return;

    const isFullscreen = document.fullscreenElement ||
                        document.webkitFullscreenElement ||
                        document.mozFullScreenElement;

    if (!isFullscreen) {
      const requestFullscreen = iframe.requestFullscreen ||
                               iframe.webkitRequestFullscreen ||
                               iframe.mozRequestFullScreen ||
                               iframe.msRequestFullscreen;
      if (requestFullscreen) {
        requestFullscreen.call(iframe).catch(err => console.error(err));
      }
    } else {
      const exitFullscreen = document.exitFullscreen ||
                            document.webkitExitFullscreen ||
                            document.mozCancelFullScreen ||
                            document.msExitFullscreen;
      if (exitFullscreen) {
        exitFullscreen.call(document);
      }
    }
  }

  function restartGame() {
    const iframe = document.querySelector('.game-iframe') as HTMLIFrameElement;
    if (iframe) {
      // 先记录当前游戏结束
      recordGameEnd();
      
      // 重置交互计数器
      iframeInteractionCount = 0;
      lastIframeInteraction = null;
      
      // 重新加载游戏
      iframe.src = iframe.src;
      
      // 重新开始统计
      setTimeout(() => {
        initializeGameStats();
      }, 1000);
      
      console.log('🔄 游戏重启，统计数据已重置');
    }
  }

  function toggleFavorite() {
    // 获取当前游戏的slug
    const gameSlug = window.location.pathname.split('/').pop();
    if (!gameSlug) return;

    try {
      // 从localStorage获取收藏列表
      const favorites = (() => {
        try {
          return JSON.parse(localStorage.getItem('favoriteGames') || '[]');
        } catch (e) {
          return [];
        }
      })();
      const favoriteBtn = document.querySelector('.favorite-btn');
      const heartIcon = favoriteBtn?.querySelector('i');
      
      // 检查是否已收藏
      const isFavorited = favorites.includes(gameSlug);
      
      if (isFavorited) {
        // 移除收藏
        const index = favorites.indexOf(gameSlug);
        favorites.splice(index, 1);
        
        // 更新UI
        if (heartIcon) {
          heartIcon.className = 'far fa-heart';
        }
        if (favoriteBtn) {
          favoriteBtn.style.background = '#6B7280';
          favoriteBtn.style.color = 'white';
        }
        
        console.log(`已移除 ${gameSlug} 从收藏列表`);
        
        // 显示提示
        showNotification('Removed from favorites', 'removed');
      } else {
        // 添加收藏
        favorites.push(gameSlug);
        
        // 更新UI
        if (heartIcon) {
          heartIcon.className = 'fas fa-heart';
        }
        if (favoriteBtn) {
          favoriteBtn.style.background = '#EC4899';
          favoriteBtn.style.color = 'white';
        }
        
        console.log(`已添加 ${gameSlug} 到收藏列表`);
        
        // 显示提示
        showNotification('Added to favorites', 'added');
      }
      
      // 保存到localStorage
      try {
        localStorage.setItem('favoriteGames', JSON.stringify(favorites));
      } catch (e) {
        console.warn('localStorage not available');
      }
      
      // 触发全局事件，通知其他组件
      window.dispatchEvent(new CustomEvent('favoritesChanged', {
        detail: { gameSlug, isFavorite: !isFavorited }
      }));
      
    } catch (error) {
      console.error('收藏操作失败:', error);
      showNotification('Something went wrong', 'error');
    }
  }

  function handleShareClick(button: HTMLElement): void {
    const title = button.getAttribute('data-game-title') || '';
    const description = button.getAttribute('data-game-description') || '';
    const image = button.getAttribute('data-game-image') || '';
    const url = window.location.href;
    
    // 调用ShareModal的全局openShareModal函数
    if (typeof window.openShareModal === 'function') {
      window.openShareModal(title, url, description, image);
    } else {
      // 回退方案
      shareGameFallback(title, url);
    }
  }

  function shareGameFallback(title: string, url: string): void {
    // 直接调用ShareModal的全局函数
    if (navigator.share) {
      navigator.share({
        title: title,
        url: url
      });
    } else {
      navigator.clipboard.writeText(url);
      showNotification('Game link copied to clipboard!', 'info');
    }
  }

  // 显示通知函数
  function showNotification(message: string, type: string = 'info'): void {
    // 移除现有通知
    const existingNotification = document.querySelector('.favorite-notification');
    if (existingNotification) {
      existingNotification.remove();
    }

    // 创建通知元素
    const notification = document.createElement('div');
    notification.className = `favorite-notification ${type}`;
    notification.innerHTML = `
      <div class="notification-content">
        <i class="fas ${type === 'added' ? 'fa-heart' : type === 'removed' ? 'fa-heart-broken' : 'fa-exclamation-triangle'}"></i>
        <span>${message}</span>
      </div>
    `;

    // 添加样式
    Object.assign(notification.style, {
      position: 'fixed',
      top: '20px',
      right: '20px',
      zIndex: '9999',
      padding: '1rem 1.5rem',
      borderRadius: '12px',
      background: type === 'added' ? '#10B981' : type === 'removed' ? '#EF4444' : '#F59E0B',
      color: 'white',
      fontWeight: '600',
      fontSize: '0.9rem',
      boxShadow: '0 8px 24px rgba(0, 0, 0, 0.15)',
      transform: 'translateX(100%)',
      transition: 'transform 0.3s ease',
      backdropFilter: 'blur(10px)'
    });

    // 添加到页面
    document.body.appendChild(notification);

    // 动画显示
    setTimeout(() => {
      notification.style.transform = 'translateX(0)';
    }, 100);

    // 3秒后自动隐藏
    setTimeout(() => {
      notification.style.transform = 'translateX(100%)';
      setTimeout(() => {
        if (notification.parentNode) {
          notification.parentNode.removeChild(notification);
        }
      }, 300);
    }, 3000);
  }

  // 初始化收藏状态
  function initializeFavoriteState(): void {
    const gameSlug = window.location.pathname.split('/').pop();
    if (!gameSlug) return;

    try {
      const favorites = (() => {
        try {
          return JSON.parse(localStorage.getItem('favoriteGames') || '[]');
        } catch (e) {
          return [];
        }
      })();
      const isFavorited = favorites.includes(gameSlug);
      
      const favoriteBtn = document.querySelector('.favorite-btn') as HTMLElement;
      const heartIcon = favoriteBtn?.querySelector('i');
      
      if (isFavorited) {
        if (heartIcon) {
          heartIcon.className = 'fas fa-heart';
        }
        if (favoriteBtn) {
          favoriteBtn.style.background = '#EC4899';
          favoriteBtn.style.color = 'white';
        }
      } else {
        if (heartIcon) {
          heartIcon.className = 'far fa-heart';
        }
        if (favoriteBtn) {
          favoriteBtn.style.background = '#6B7280';
          favoriteBtn.style.color = 'white';
        }
      }
    } catch (error) {
      console.error('初始化收藏状态失败:', error);
    }
  }

  // 将函数绑定到全局作用域
  (window as any).toggleFullscreen = toggleFullscreen;
  (window as any).restartGame = restartGame;
  (window as any).toggleFavorite = toggleFavorite;
  (window as any).handleShareClick = handleShareClick;

  // 游戏统计数据记录功能 (iframe优化版)
  let gameStartTime: number | null = null;
  let gameSlug: string | null = null;
  let iframeInteractionCount = 0;
  let lastIframeInteraction: any = null;

  function initializeGameStats(): void {
    gameSlug = window.location.pathname.split('/').pop() || null;
    if (!gameSlug) return;

    // 等待统计管理器加载
    if (typeof window.gameStatsManager === 'undefined') {
      setTimeout(initializeGameStats, 100);
      return;
    }

    // 记录游戏开始播放
    const gameInfo = {
      title: document.querySelector('.game-main-title')?.textContent || gameSlug,
      category: document.querySelector('.category-tag')?.textContent?.toLowerCase() || 'unknown'
    };

    window.gameStatsManager.recordGameStart(gameSlug, gameInfo);
    gameStartTime = Date.now();

    // 设置iframe交互监听
    setupIframeInteractionTracking();

    console.log(`🎮 开始记录游戏统计 (iframe优化): ${gameSlug}`);
  }

  function setupIframeInteractionTracking(): void {
    const iframe = document.querySelector('.game-iframe') as HTMLIFrameElement;
    if (!iframe) return;

    // 监听iframe的鼠标事件
    iframe.addEventListener('mouseenter', () => {
      console.log('🖱️ 鼠标进入iframe');
      recordIframeInteraction('mouseenter');
    });

    iframe.addEventListener('mouseleave', () => {
      console.log('🖱️ 鼠标离开iframe');
      recordIframeInteraction('mouseleave');
    });

    // 监听iframe的点击事件
    iframe.addEventListener('click', () => {
      console.log('🖱️ 点击iframe');
      recordIframeInteraction('click');
    });

    // 监听iframe的焦点事件
    iframe.addEventListener('focus', () => {
      console.log('🎯 iframe获得焦点');
      recordIframeInteraction('focus');
    });

    iframe.addEventListener('blur', () => {
      console.log('🎯 iframe失去焦点');
      recordIframeInteraction('blur');
    });

    // 尝试监听iframe内的PostMessage事件
    window.addEventListener('message', (event) => {
      // 检查消息来源是否为游戏iframe
      if (event.source === iframe.contentWindow) {
        console.log('📨 收到iframe内部消息:', event.data);
        recordIframeInteraction('postmessage', event.data);
      }
    });

    // 监听键盘事件（当iframe有焦点时）
    document.addEventListener('keydown', (event) => {
      if (document.activeElement === iframe) {
        console.log('⌨️ iframe内键盘按下:', event.key);
        recordIframeInteraction('keydown', event.key);
      }
    });

    // 定期检查iframe是否还在加载
    let loadCheckInterval = setInterval(() => {
      try {
        // 尝试访问iframe的contentDocument来检测加载状态
        if (iframe.contentDocument && iframe.contentDocument.readyState === 'complete') {
          console.log('✅ iframe游戏完全加载完成');
          recordIframeInteraction('loaded');
          clearInterval(loadCheckInterval);
          
          // 尝试注入交互监听脚本到iframe
          injectInteractionScript(iframe);
        }
      } catch (e) {
        // 跨域限制，无法访问iframe内容，这是正常的
        console.log('🔒 iframe跨域限制，使用外部监听');
        clearInterval(loadCheckInterval);
      }
    }, 1000);

    console.log('👂 iframe交互监听已设置');
  }

  function recordIframeInteraction(type: string, data: any = null): void {
    iframeInteractionCount++;
    lastIframeInteraction = {
      type: type,
      timestamp: Date.now(),
      data: data
    };

    // 通知统计管理器用户正在与游戏交互
    if (window.gameStatsManager && gameSlug) {
      window.gameStatsManager.updateGameActivity(gameSlug);
    }

    console.log(`🎯 iframe交互记录: ${type}`, data);
  }

  function injectInteractionScript(iframe: HTMLIFrameElement): void {
    try {
      // 尝试向iframe注入交互监听脚本
      const script = iframe.contentDocument!.createElement('script');
      script.textContent = `
        // 游戏内交互监听脚本
        let interactionCount = 0;
        
        function reportInteraction(type, detail) {
          interactionCount++;
          window.parent.postMessage({
            type: 'gameInteraction',
            action: type,
            detail: detail,
            count: interactionCount,
            timestamp: Date.now()
          }, '*');
        }
        
        // 监听各种游戏交互
        ['click', 'mousedown', 'mouseup', 'keydown', 'keyup', 'touchstart', 'touchend'].forEach(eventType => {
          document.addEventListener(eventType, (e) => {
            reportInteraction(eventType, {
              target: e.target.tagName,
              x: e.clientX || (e.touches && e.touches[0] && e.touches[0].clientX),
              y: e.clientY || (e.touches && e.touches[0] && e.touches[0].clientY)
            });
          }, true);
        });
        
        // 监听游戏特定事件（如果游戏支持）
        window.addEventListener('gameEvent', (e) => {
          reportInteraction('gameEvent', e.detail);
        });
        
        console.log('🎮 游戏内交互监听脚本已注入');
      `;
      
      iframe.contentDocument!.head.appendChild(script);
      console.log('✅ 成功注入iframe交互监听脚本');
    } catch (error: any) {
      console.log('❌ 无法注入iframe脚本 (跨域限制):', error.message);
    }
  }

  function recordGameEnd(): void {
    if (!gameSlug || !gameStartTime || typeof window.gameStatsManager === 'undefined') return;

    const playTime = Math.floor((Date.now() - gameStartTime) / 1000); // 转换为秒
    
    // 计算交互密度（每分钟交互次数）
    const interactionDensity = playTime > 0 ? (iframeInteractionCount / (playTime / 60)) : 0;
    
    // 将交互数据传递给统计管理器
    window.gameStatsManager.recordGameEnd(gameSlug, playTime);
    
    // 记录iframe特定统计
    if (window.gameStatsManager?.iframeStats?.[gameSlug]) {
      const iframeStatsForGame = window.gameStatsManager.iframeStats[gameSlug];
      if (iframeStatsForGame) {
        iframeStatsForGame.interactionCount = iframeInteractionCount;
        iframeStatsForGame.interactionDensity = interactionDensity;
        iframeStatsForGame.lastInteraction = lastIframeInteraction;
      }
    }

    console.log(`🎮 记录游戏结束 (iframe优化): ${gameSlug}, 游戏时长: ${playTime}秒, 交互次数: ${iframeInteractionCount}, 交互密度: ${interactionDensity.toFixed(2)}/分钟`);
  }

  // 页面加载后初始化收藏状态和游戏统计
  document.addEventListener('DOMContentLoaded', () => {
    initializeFavoriteState();
    
    // 初始化iframe懒加载
    initializeIframeLazyLoading();
    
    // 延迟初始化游戏统计，确保游戏已开始加载
    setTimeout(() => {
      initializeGameStats();
    }, 2000);
  });

  // 🚀 iframe懒加载优化函数
  function initializeIframeLazyLoading() {
    const placeholder = document.getElementById('iframePlaceholder');
    const iframe = document.getElementById('gameIframe');
    const loadGameBtn = document.getElementById('loadGameBtn');
    
    if (!placeholder || !iframe || !loadGameBtn) {
      console.warn('❌ iframe懒加载初始化失败：找不到必要元素');
      return;
    }

    // 设置Intersection Observer来检测何时显示加载按钮
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // 用户滚动到游戏区域，自动显示加载按钮
          loadGameBtn.style.transform = 'scale(1.05)';
          loadGameBtn.style.boxShadow = '0 4px 20px rgba(99, 102, 241, 0.4)';
          
          // 3秒后自动加载游戏（可选）
          setTimeout(() => {
            if (placeholder.style.display !== 'none') {
              autoLoadGame();
            }
          }, 3000);
          
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.5 // 当50%的游戏区域可见时触发
    });

    const gameIframeWrapper = document.getElementById('gameIframeWrapper');
    if (gameIframeWrapper) {
      observer.observe(gameIframeWrapper);
    }

    console.log('👁️ iframe懒加载观察器已设置');
  }

  // 🎮 手动加载游戏iframe
  window.loadGameIframe = function(): void {
    const placeholder = document.getElementById('iframePlaceholder');
    const iframe = document.getElementById('gameIframe') as HTMLIFrameElement;
    const loadGameBtn = document.getElementById('loadGameBtn') as HTMLButtonElement;
    
    if (!placeholder || !iframe) {
      console.error('❌ 找不到iframe元素');
      return;
    }

    // 显示加载状态
    loadGameBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
    loadGameBtn.disabled = true;

    // 开始加载iframe
    const iframeSrc = iframe.getAttribute('data-src');
    if (iframeSrc) {
      console.log('🚀 开始加载游戏iframe:', iframeSrc);
      
      // 记录加载开始时间
      const loadStartTime = Date.now();
      
      // 设置iframe src触发加载
      iframe.src = iframeSrc;
      
      // 监听iframe加载事件
      iframe.onload = function() {
        const loadTime = Date.now() - loadStartTime;
        console.log(`✅ iframe加载完成，耗时: ${loadTime}ms`);
        
        // 隐藏占位符，显示iframe
        placeholder.style.opacity = '0';
        iframe.classList.remove('hidden');
        
        setTimeout(() => {
          placeholder.style.display = 'none';
        }, 300);
        
        // 记录性能数据
        if (window.gameStatsManager) {
          window.gameStatsManager.recordIframeLoadTime(gameSlug!, loadTime);
        }
      };
      
      // 监听iframe加载错误
      iframe.onerror = function() {
        console.error('❌ iframe加载失败');
        loadGameBtn.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Load Failed - Retry';
        loadGameBtn.disabled = false;
        
        // 显示错误提示
        const errorMsg = document.createElement('div');
        errorMsg.className = 'iframe-error';
        errorMsg.innerHTML = '⚠️ Game failed to load. Please try again or check your connection.';
        const placeholderContent = placeholder.querySelector('.placeholder-content');
        if (placeholderContent) {
          placeholderContent.appendChild(errorMsg);
        }
      };
    }
  };

  // 🤖 自动加载游戏（用户滚动到游戏区域后自动触发）
  function autoLoadGame(): void {
    const placeholder = document.getElementById('iframePlaceholder');
    const loadGameBtn = document.getElementById('loadGameBtn') as HTMLButtonElement;
    
    if (placeholder && placeholder.style.display !== 'none') {
      console.log('🤖 自动加载游戏iframe');
      
      // 添加自动加载提示
      loadGameBtn.innerHTML = '<i class="fas fa-rocket"></i> Auto Loading...';
      
      setTimeout(() => {
        if (window.loadGameIframe) {
          window.loadGameIframe();
        }
      }, 1000);
    }
  }

  // 🔄 重启游戏优化
  window.restartGame = function(): void {
    const iframe = document.getElementById('gameIframe') as HTMLIFrameElement;
    if (iframe && iframe.src) {
      console.log('🔄 重启游戏');
      
      // 记录重启事件
      if (window.gameStatsManager && gameSlug) {
        window.gameStatsManager.recordGameRestart(gameSlug);
      }
      
      // 重新加载iframe
      iframe.src = iframe.src;
      
      // 显示重启提示
      showGameNotification('🔄 Game Restarted', 'success');
    } else {
      console.warn('⚠️ 游戏尚未加载，无法重启');
      showGameNotification('⚠️ Please load the game first', 'warning');
    }
  };

  // 📺 全屏功能优化（兼容性修复）
  window.toggleFullscreen = function(): void {
    const iframe = document.getElementById('gameIframe') as HTMLIFrameElement;
    if (!iframe) {
      showGameNotification('⚠️ Please load the game first', 'warning');
      return;
    }

    const isFullscreen = document.fullscreenElement ||
                        document.webkitFullscreenElement ||
                        document.mozFullScreenElement;

    if (!isFullscreen) {
      // 请求全屏（兼容不同浏览器）
      const requestFullscreen = iframe.requestFullscreen ||
                               iframe.webkitRequestFullscreen ||
                               iframe.mozRequestFullScreen ||
                               iframe.msRequestFullscreen;

      if (requestFullscreen) {
        requestFullscreen.call(iframe).then(() => {
          console.log('📺 进入全屏模式');
          showGameNotification('📺 Fullscreen Mode Enabled', 'success');

          if (window.gameStatsManager && gameSlug) {
            window.gameStatsManager.recordGameFullscreen(gameSlug, true);
          }
        }).catch(err => {
          console.error('❌ 无法进入全屏:', err);
          showGameNotification('❌ Fullscreen not supported', 'error');
        });
      } else {
        showGameNotification('❌ Fullscreen not supported', 'error');
      }
    } else {
      // 退出全屏（兼容不同浏览器）
      const exitFullscreen = document.exitFullscreen ||
                            document.webkitExitFullscreen ||
                            document.mozCancelFullScreen ||
                            document.msExitFullscreen;

      if (exitFullscreen) {
        exitFullscreen.call(document).then(() => {
          console.log('📱 退出全屏模式');
          showGameNotification('📱 Fullscreen Mode Disabled', 'info');

          if (window.gameStatsManager && gameSlug) {
            window.gameStatsManager.recordGameFullscreen(gameSlug, false);
          }
        });
      }
    }
  };

  // 🎮 显示游戏通知
  function showGameNotification(message: string, type: string = 'info'): void {
    // 移除现有通知
    const existingNotification = document.querySelector('.game-notification');
    if (existingNotification) {
      existingNotification.remove();
    }

    // 创建通知元素
    const notification = document.createElement('div');
    notification.className = `game-notification game-notification-${type}`;
    notification.innerHTML = `
      <div class="notification-content">
        <span>${message}</span>
        <button class="notification-close" onclick="this.parentElement.parentElement.remove()">
          <i class="fas fa-times"></i>
        </button>
      </div>
    `;

    // 添加到页面
    document.body.appendChild(notification);

    // 3秒后自动移除
    setTimeout(() => {
      if (notification.parentNode) {
        notification.remove();
      }
    }, 3000);
  }
</script> 

