---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import fs from 'fs';
import path from 'path';

const gamesPath = path.join(process.cwd(), 'src', 'data', 'games.json');
const allGames = JSON.parse(fs.readFileSync(gamesPath, 'utf-8'));

// 按分类选择最佳游戏
const bestGames = {
  math: allGames.filter(g => g.category === 'math').slice(0, 5),
  science: allGames.filter(g => g.category === 'science').slice(0, 5),
  language: allGames.filter(g => g.category === 'language').slice(0, 5),
  puzzle: allGames.filter(g => g.category === 'puzzle').slice(0, 5)
};
---

<BaseLayout
  title="Best Educational Games for Kids 2026 | Top Free Learning Games"
  description="Discover the best free educational games for kids. Top-rated math, science, language, and puzzle games for ages 6-18. No downloads required."
>
  <div class="best-games-page">
    <h1>Best Educational Games for Kids 2026</h1>
    <p>Curated collection of the top free educational games across all subjects. Perfect for homeschooling, classroom use, or independent learning.</p>

    <section>
      <h2>Best Math Games</h2>
      <p>Top 5 math games that make learning numbers, algebra, and geometry fun.</p>
      <div class="game-grid">
        {bestGames.math.map(game => <GameCard game={game} />)}
      </div>
    </section>

    <section>
      <h2>Best Science Games</h2>
      <p>Explore physics, chemistry, and biology through interactive gameplay.</p>
      <div class="game-grid">
        {bestGames.science.map(game => <GameCard game={game} />)}
      </div>
    </section>

    <section>
      <h2>Best Language Games</h2>
      <p>Improve vocabulary, spelling, and reading comprehension.</p>
      <div class="game-grid">
        {bestGames.language.map(game => <GameCard game={game} />)}
      </div>
    </section>

    <section>
      <h2>Best Puzzle Games</h2>
      <p>Develop critical thinking and problem-solving skills.</p>
      <div class="game-grid">
        {bestGames.puzzle.map(game => <GameCard game={game} />)}
      </div>
    </section>
  </div>

  <style>
    .best-games-page {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    section {
      margin: 3rem 0;
    }
    .game-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-top: 1rem;
    }
  </style>
</BaseLayout>
