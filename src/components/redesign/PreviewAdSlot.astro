---
interface Props {
  className?: string;
  slot?: string;
  format?: 'auto' | 'horizontal' | 'rectangle';
  label?: string;
}

const {
  className = '',
  slot = '3769513448',
  format = 'auto',
  label = 'Advertisement',
} = Astro.props;
---

<section class={`preview-ad ${className}`} aria-label={label}>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-6509438403900392"
    data-ad-slot={slot}
    data-ad-format={format === 'rectangle' ? 'auto' : format}
    data-full-width-responsive="true"
  ></ins>
  <span class="preview-ad-label">{label}</span>
  <script is:inline>
    try {
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    } catch {}
  </script>
</section>
