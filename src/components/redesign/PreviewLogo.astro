---
interface Props {
  compact?: boolean;
  markOnly?: boolean;
}

const { compact = false, markOnly = false } = Astro.props;
---

<a class={`preview-logo ${compact ? 'compact' : ''} ${markOnly ? 'mark-only' : ''}`} href="/redesign-preview/" aria-label="EduGameHQ redesign preview home">
  <span class="preview-logo-mark-wrap" aria-hidden="true">
    <img src="/images/brand/edugamehq-icon-transparent.png" alt="" class="preview-logo-mark" loading="eager" />
  </span>
  {!markOnly && (
    <span class="preview-logo-word">
      <strong><span>Edu</span><em>Game</em></strong><b>HQ</b>
    </span>
  )}
</a>
