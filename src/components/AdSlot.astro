---
interface Props {
  className?: string;
  format?: 'auto' | 'horizontal' | 'rectangle';
  label?: string;
  placement?: 'game-below-player' | 'game-after-info' | 'content';
  slot?: string;
}

const {
  className = '',
  format = 'auto',
  label = 'Advertisement',
  placement = 'content',
  slot = '3769513448',
} = Astro.props;

const adFormat = format === 'rectangle' ? 'auto' : format;
---

<section class={`ad-slot ad-slot--${placement} ${className}`} aria-label={label}>
  <div class="ad-slot-inner">
    <div class="ad-slot-label">{label}</div>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-6509438403900392"
      data-ad-slot={slot}
      data-ad-format={adFormat}
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
</section>

<style>
  .ad-slot {
    width: 100%;
    margin: 1.5rem 0 2rem;
    display: flex;
    justify-content: center;
  }

  .ad-slot-inner {
    width: min(100%, 760px);
    min-height: 118px;
    padding: 0.75rem;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    background: #FFFFFF;
    box-shadow: 0 1px 4px rgba(15, 23, 42, 0.05);
  }

  .ad-slot-label {
    margin-bottom: 0.5rem;
    color: #94A3B8;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  .ad-slot--game-below-player {
    margin-top: 1rem;
  }

  .ad-slot--game-after-info .ad-slot-inner {
    min-height: 250px;
  }

  @media (max-width: 767px) {
    .ad-slot {
      margin: 1.25rem 0 1.75rem;
    }

    .ad-slot-inner {
      min-height: 104px;
      padding: 0.625rem;
      border-radius: 6px;
    }

    .ad-slot--game-after-info .ad-slot-inner {
      min-height: 180px;
    }
  }
</style>
