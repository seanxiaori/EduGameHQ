---
// src/components/ui/Logo.astro
// EduGameHQ Logo - shared raster brand mark
---
<div class="logo-mark-wrap flex-shrink-0">
  <img src="/images/brand/edugamehq-icon-transparent.png" alt="" class="logo-mark" loading="eager" />
</div>

<div class="logo-text">
  <strong><span class="logo-edu">Edu</span><span class="logo-game">Game</span></strong><span class="logo-hq">HQ</span>
</div>

<style>
  .logo-mark-wrap {
    display: inline-grid;
    place-items: center;
    width: 54px;
    height: 42px;
    overflow: hidden;
  }

  .logo-mark {
    width: 64px;
    height: 44px;
    object-fit: contain;
    mix-blend-mode: screen;
    transition: transform 0.2s ease;
  }

  .logo-text {
    display: flex;
    align-items: baseline;
    font-family: 'Inter', 'Space Grotesk', sans-serif;
    font-weight: 800;
    letter-spacing: 0;
  }

  .logo-text strong {
    display: inline-flex;
  }

  .logo-edu {
    font-size: 24px;
    color: #EAF2FF;
  }

  .logo-game {
    font-size: 24px;
    color: #10B981;
  }

  .logo-hq {
    font-size: 18px;
    color: #FFBF1A;
    font-weight: 700;
  }

  .nav-logo:hover .logo-mark {
    transform: scale(1.05);
  }

  @media (max-width: 640px) {
    .logo-edu,
    .logo-game { font-size: 20px; }
    .logo-hq { font-size: 16px; }
  }
</style>
