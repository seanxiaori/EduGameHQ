---
interface Props {
  title: string;
  description: string;
  robots?: string;
  canonical?: string;
}

const { title, description, robots = 'noindex, nofollow', canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robots} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/brand/edugamehq-icon-transparent.png?v=7.0" />
    <link rel="apple-touch-icon" href="/images/brand/edugamehq-icon-transparent.png?v=7.0" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0b63ce" />
    <meta name="google-adsense-account" content="ca-pub-6509438403900392" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6509438403900392" crossorigin="anonymous" is:inline></script>
    {canonical && <link rel="canonical" href={canonical} />}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    text-rendering: optimizeLegibility;
  }

  body {
    margin: 0;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }
</style>
